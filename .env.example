# ─────────────────────────────────────────────────────────────────────────────
# Umami Analytics MCP — example configuration
# Copy to `.env` for local dev, or set these as environment variables in your
# MCP client config / Vercel project. NEVER commit a real .env.
# ─────────────────────────────────────────────────────────────────────────────

# === Option A: Umami Cloud (https://cloud.umami.is) ===
# Create a key at: Dashboard → Settings → API keys
# UMAMI_API_KEY=your_cloud_api_key
# UMAMI_CLOUD_REGION=us            # optional: us | eu

# === Option B: Self-hosted Umami ===
# UMAMI_API_URL=https://stats.example.com   # base URL; "/api" is appended automatically
# UMAMI_USERNAME=admin
# UMAMI_PASSWORD=change-me
# (Self-hosted instances that issue API keys may instead set UMAMI_API_KEY + UMAMI_API_URL.)

# === Optional, both modes ===
# UMAMI_TEAM_ID=...                # scope website listings to a team
# UMAMI_DEFAULT_TIMEZONE=UTC       # IANA tz used by time-series tools

# === Capability tiers (default: READ-ONLY) ===
# UMAMI_ENABLE_WRITE=1             # expose create/update + send-event tools
# UMAMI_ENABLE_ADMIN=1             # expose user-management tools (self-hosted only)
# UMAMI_ALLOW_DESTRUCTIVE=1        # ALSO required to expose delete/reset tools

# === Remote transports only (Vercel / standalone HTTP) ===
# Long random shared secret required to call the hosted endpoint.
# MCP_AUTH_TOKEN=replace-with-a-long-random-string
